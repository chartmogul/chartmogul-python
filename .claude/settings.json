{
  "permissions": {
    "allow": [
      "Bash(pip install:*)",
      "Bash(python -m unittest:*)",
      "Bash(python -m pytest:*)",
      "Bash(flake8:*)",
      "Bash(coverage:*)",
      "Bash(python setup.py sdist:*)",
      "Bash(python --version)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git branch:*)",
      "Bash(git fetch:*)",
      "Bash(git stash:*)",
      "Bash(git checkout:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git pull:*)",
      "Bash(git cherry-pick:*)",
      "Bash(git reset:*)",
      "Bash(gh pr:*)"
    ],
    "deny": [
      "Read(./.env*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "./.claude/hooks/session-start-setup.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "./.claude/hooks/post-edit-lint.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "./.claude/hooks/post-stop-validate.sh"
          }
        ]
      }
    ]
  }
}
